<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hospital_white"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_lock"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_lock_idle_lock"
        app:tint="@color/hospital_blue_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="64dp" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Security PIN"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/hospital_blue_primary"
        app:layout_constraintTop_toBottomOf="@id/iv_lock"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/et_pin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:hint="****"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:gravity="center"
        android:textSize="32sp"
        android:letterSpacing="0.5"
        android:background="@null"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="48dp" />

    <View
        android:layout_width="200dp"
        android:layout_height="2dp"
        android:background="@color/hospital_blue_primary"
        app:layout_constraintTop_toBottomOf="@id/et_pin"
        app:layout_constraintLeft_toLeftOf="@id/et_pin"
        app:layout_constraintRight_toRightOf="@id/et_pin" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_bio_auth"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use Fingerprint / Face"
        android:textColor="@color/hospital_blue_primary"
        app:layout_constraintTop_toBottomOf="@id/et_pin"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="64dp"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
